{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "node16",
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,
    
    /* ✅ FIXED: Enable strict type checking */
    "strict": true, 

    /* ✅ ADDED: Prevent capitalization bugs on Linux servers */
    "forceConsistentCasingInFileNames": true,

    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "**/*.test.ts"]
}